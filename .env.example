# Slopagotchi backend env. These power the /api serverless functions (the
# scoring pipeline, ATProto reads/writes, Redis). The Vite frontend needs none
# of them — it talks to /api. Add these to the Vercel project (or .env.local for
# `vercel dev`). Tests run without any of them (unit tests mock; integration
# tests skip when their vars are absent).

# --- Upstash Redis (single datastore: idempotency set, registry, cached pet state) ---
# Provision with `vercel integration add upstash/upstash-kv`. The integration
# injects <PREFIX>_KV_REST_API_URL / _TOKEN (any prefix) which the app auto-detects,
# OR set the plain names below. Either pair works.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# e.g. from the Vercel Upstash-KV integration (auto-detected, prefix may vary):
# SLOPAGOTCHI_KV_REST_API_URL=
# SLOPAGOTCHI_KV_REST_API_TOKEN=

# --- Featherless (OpenAI-compatible inference for the slop scorer) ---
FEATHERLESS_API_KEY=
# Optional override; defaults to Qwen/Qwen2.5-7B-Instruct (fast + available on
# shared infra). Qwen2.5-Coder-32B is higher quality but often capacity-queued.
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Slopagotchi ATProto service account (writes app.slopgotchi.* records) ---
# The PDS host (e.g. https://bsky.social or the account's own PDS).
SLOPGOTCHI_PDS=https://bsky.social
# The service account handle or DID used to log in.
SLOPGOTCHI_IDENTIFIER=
# An app password (NOT the main account password). Generated in the PDS settings.
SLOPGOTCHI_APP_PASSWORD=

# --- Cron protection ---
# Shared secret required by the cron poll route (Authorization: Bearer ...).
# Vercel Cron sends this automatically when CRON_SECRET is set on the project.
CRON_SECRET=

# --- Tuning (optional; defaults in code) ---
# Rounds scored per join's first backfill chunk (scored concurrently).
MAX_BACKFILL_ROUNDS=9
# Max DIDs scanned per cron invocation.
CRON_MAX_DIDS=10
# Total rounds scored per cron invocation (across DIDs); ~3 concurrent waves/60s.
CRON_MAX_ROUNDS=9
# Per-developer cap: only the most recent N rounds are ever scored (health uses
# the recent 10; receipt shows recent PRs). Raise to backfill deeper history.
SCORE_WINDOW=50
