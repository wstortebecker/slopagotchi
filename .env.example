# ============================================================================
# FRONTEND — Auth = Clerk, Billing = your own Stripe (direct Stripe Checkout).
# Copy this file to .env and fill in the values. .env is gitignored.
# ============================================================================

# ── Clerk (authentication) ───────────────────────────────────────────────────
# Clerk Dashboard → API Keys. VITE_ prefix exposes the publishable key to the
# browser (safe). The Secret Key is server-only — never expose it to the client.
# NOTE: for production use a Clerk PRODUCTION instance (pk_live_/sk_live_), not
# the development instance keys.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ── Stripe (billing) ─────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API keys → Secret key.
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe Dashboard → Products → your product → its recurring Price id (price_…).
STRIPE_PRICE_ID=price_xxx

# Optional: only needed if the request Origin header is unavailable (rare).
# PUBLIC_BASE_URL=https://your-app.vercel.app

# ── Admin metrics dashboard (/admin) ─────────────────────────────────────────
# Comma-separated Clerk emails allowed to view live Stripe revenue at /admin.
ADMIN_EMAILS=you@example.com


# ============================================================================
# BACKEND — powers the /api serverless functions (scoring pipeline, ATProto,
# Redis). The Vite frontend needs none of these — it talks to /api. Add these
# to the Vercel project (or .env.local for `vercel dev`). Tests run without them.
# ============================================================================

# --- Upstash Redis (single datastore: idempotency set, registry, cached pet state) ---
# Provision with `vercel integration add upstash/upstash-kv`. The integration
# injects <PREFIX>_KV_REST_API_URL / _TOKEN (any prefix) which the app auto-detects,
# OR set the plain names below. Either pair works.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# e.g. from the Vercel Upstash-KV integration (auto-detected, prefix may vary):
# SLOPAGOTCHI_KV_REST_API_URL=
# SLOPAGOTCHI_KV_REST_API_TOKEN=

# --- Featherless (OpenAI-compatible inference for the slop scorer) ---
FEATHERLESS_API_KEY=
# Optional override; defaults to Qwen/Qwen2.5-7B-Instruct (fast + available on
# shared infra). Qwen2.5-Coder-32B is higher quality but often capacity-queued.
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Slopagotchi ATProto service account (writes app.slopgotchi.* records) ---
# The PDS host (e.g. https://bsky.social or the account's own PDS).
SLOPGOTCHI_PDS=https://bsky.social
# The service account handle or DID used to log in.
SLOPGOTCHI_IDENTIFIER=
# An app password (NOT the main account password). Generated in the PDS settings.
SLOPGOTCHI_APP_PASSWORD=

# --- GitHub scoring (optional; enables scoring GitHub PRs alongside Tangled) ---
# A fine-grained PAT with public read access (no scopes needed beyond public
# repos). When unset, the /api/github/* routes return 503 and the cron skips
# GitHub entirely — Tangled scoring is unaffected.
GITHUB_TOKEN=

# --- Cron protection ---
# Shared secret required by the cron poll route (Authorization: Bearer ...).
# Vercel Cron sends this automatically when CRON_SECRET is set on the project.
CRON_SECRET=

# --- Tuning (optional; defaults in code) ---
# Rounds scored per join's first backfill chunk (scored concurrently).
MAX_BACKFILL_ROUNDS=9
# Max DIDs scanned per cron invocation.
CRON_MAX_DIDS=10
# Total rounds scored per cron invocation (across DIDs); ~3 concurrent waves/60s.
CRON_MAX_ROUNDS=9
# Per-developer cap: only the most recent N rounds are ever scored (health uses
# the recent 10; receipt shows recent PRs). Raise to backfill deeper history.
SCORE_WINDOW=50
# GitHub's own round budget per cron invocation, separate from Tangled's so one
# source can't starve the other. Also the first GitHub backfill chunk size.
GITHUB_MAX_ROUNDS=5
# Recency window of GitHub PRs enumerated per pass (separate from SCORE_WINDOW).
GITHUB_SCORE_WINDOW=30
